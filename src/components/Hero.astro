---
import StarField from './StarField.astro';
---

<section class="hero" id="hero">
  <StarField />
  <div class="hero-content container">
    <div class="hero-card">
      <p class="hero-greeting">Hi, I'm</p>
      <h1 class="hero-name">
        <span class="gradient-text">Andrew Brown</span>
      </h1>
      <p class="hero-tagline">
        Software engineer. Security practitioner.<br />
        <span class="hero-tagline-sub">Human-first AI developer.</span>
      </p>
      <div class="hero-actions">
        <a href="/projects" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          View My Work
        </a>
        <a href="/#contact" class="btn btn-outline">
          Get In Touch
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding-top: var(--nav-height);
  }

  .hero-card {
    background: rgba(6, 12, 26, 0.65);
    backdrop-filter: blur(24px) saturate(150%);
    -webkit-backdrop-filter: blur(24px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-xl);
    padding: var(--space-3xl) var(--space-3xl);
    max-width: 52rem;
    text-align: center;
  }

  .hero-greeting {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--cyan);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-md);
    opacity: 0;
    animation: fadeUp 0.8s var(--ease-out) 0.2s forwards;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: var(--text-7xl);
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: var(--space-lg);
    opacity: 0;
    animation: fadeUp 0.8s var(--ease-out) 0.4s forwards;
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-2xl);
    opacity: 0;
    animation: fadeUp 0.8s var(--ease-out) 0.6s forwards;
  }

  .hero-tagline-sub {
    color: var(--text-muted);
    font-size: var(--text-lg);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 0.8s var(--ease-out) 0.8s forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-card {
      padding: var(--space-2xl) var(--space-xl);
    }

    .hero-name {
      font-size: var(--text-5xl);
    }

    .hero-tagline {
      font-size: var(--text-lg);
    }

    .hero-tagline-sub {
      font-size: var(--text-base);
    }
  }
</style>
