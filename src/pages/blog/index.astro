---
import Layout from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function estimateReadingTime(body: string | undefined) {
  if (!body) return 1;
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 250));
}

// Separate series posts from standalone posts
const standalonePosts = posts.filter(p => !p.data.series);
const seriesPosts     = posts.filter(p =>  p.data.series);

// Group by series name, sort each group ascending by seriesOrder
const seriesGroupsMap = new Map<string, typeof posts>();
for (const post of seriesPosts) {
  const name = post.data.series!;
  if (!seriesGroupsMap.has(name)) seriesGroupsMap.set(name, []);
  seriesGroupsMap.get(name)!.push(post);
}
for (const arr of seriesGroupsMap.values()) {
  arr.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
}
// Sort series blocks by most-recent post date descending
const seriesGroups = [...seriesGroupsMap.entries()].sort((a, b) => {
  const aDate = Math.max(...a[1].map(p => p.data.date.valueOf()));
  const bDate = Math.max(...b[1].map(p => p.data.date.valueOf()));
  return bDate - aDate;
});

const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))].sort();
const [featured, ...rest] = standalonePosts;
---

<Layout title="Blog — Andrew Brown">
  <div class="blog-page container">

    <!-- Header -->
    <header class="blog-header reveal">
      <span class="section-label">Blog</span>
      <h1 class="blog-title">Writing &amp; Dev Diary</h1>
      <p class="blog-subtitle">
        Thoughts on software engineering, cybersecurity, architecture decisions,
        and the journey of building things that matter.
        Also on <a href="https://medium.com/@wanderingastronomer" target="_blank" rel="noopener noreferrer" class="medium-link">Medium</a>.
      </p>
      <div class="blog-meta-row">
        <span class="post-count">{posts.length} articles</span>
      </div>
    </header>

    <!-- Tag filter -->
    <nav class="tag-filter reveal" aria-label="Filter by tag">
      <button class="tag-btn tag-btn--active" data-tag="all">All</button>
      {allTags.map(tag => (
        <button class="tag-btn" data-tag={tag}>{tag}</button>
      ))}
    </nav>

    <!-- Series carousels -->
    {seriesGroups.map(([seriesName, seriePosts]) => {
      const allSeriesTags = [...new Set(seriePosts.flatMap(p => p.data.tags || []))].join(',');
      return (
        <section class="series-section reveal" data-tags={allSeriesTags}>
          <div class="series-header">
            <span class="series-badge">Series</span>
            <h2 class="series-name">{seriesName}</h2>
            <span class="series-count">{seriePosts.length} {seriePosts.length === 1 ? 'part' : 'parts'}</span>
            <span class="series-scroll-hint" aria-hidden="true">scroll →</span>
          </div>
          <div class="series-carousel">
            {seriePosts.map((post, i) => (
              <a href={`/blog/${post.id}`} class="series-card" data-tags={(post.data.tags || []).join(',')}>
                <div class="series-part">Part {post.data.seriesOrder ?? i}</div>
                <div class="series-card-meta">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <span class="reading-time">{estimateReadingTime(post.body)} min read</span>
                  {post.data.canonicalUrl && <span class="medium-badge">Medium</span>}
                </div>
                {post.data.tags && (
                  <div class="series-card-tags">
                    {post.data.tags.map(tag => (
                      <span class="pill pill--sm pill--amber">{tag}</span>
                    ))}
                  </div>
                )}
                <h3 class="series-card-title">{post.data.title}</h3>
                <p class="series-card-desc">{post.data.description}</p>
                <span class="read-link series-read-link">Read <span class="read-arrow">→</span></span>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <!-- Section divider: series → articles -->
    {seriesGroups.length > 0 && (
      <div class="articles-divider reveal">
        <span class="articles-divider-line" aria-hidden="true"></span>
        <span class="articles-divider-label">Articles</span>
        <span class="articles-divider-line" aria-hidden="true"></span>
      </div>
    )}

    <!-- Featured standalone post -->
    {featured && (
      <a href={`/blog/${featured.id}`} class="featured-card reveal" data-tags={(featured.data.tags || []).join(',')}>
        <div class="featured-accent" aria-hidden="true"></div>
        <div class="featured-body">
          <div class="featured-meta">
            <span class="featured-badge">Latest</span>
            <time datetime={featured.data.date.toISOString()}>
              {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="reading-time">{estimateReadingTime(featured.body)} min read</span>
            {featured.data.canonicalUrl && <span class="medium-badge">Medium</span>}
          </div>
          {featured.data.tags && (
            <div class="featured-tags">
              {featured.data.tags.map(tag => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          )}
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          <span class="read-link">Read article <span class="read-arrow">→</span></span>
        </div>
      </a>
    )}

    <!-- Post grid -->
    <div class="posts-grid reveal-stagger">
      {rest.map(post => (
        <a href={`/blog/${post.id}`} class="post-card" data-tags={(post.data.tags || []).join(',')}>
          <div class="post-card-meta">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <span class="reading-time">{estimateReadingTime(post.body)} min read</span>
            {post.data.canonicalUrl && <span class="medium-badge">Medium</span>}
          </div>
          {post.data.tags && (
            <div class="post-card-tags">
              {post.data.tags.map(tag => (
                <span class="pill pill--sm">{tag}</span>
              ))}
            </div>
          )}
          <h3 class="post-card-title">{post.data.title}</h3>
          <p class="post-card-desc">{post.data.description}</p>
        </a>
      ))}
    </div>

  </div>
</Layout>

<script>
  const tagBtns    = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const featured   = document.querySelector<HTMLElement>('.featured-card');
  const cards      = document.querySelectorAll<HTMLElement>('.post-card');
  const seriesRows = document.querySelectorAll<HTMLElement>('.series-section');

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tagBtns.forEach(b => b.classList.remove('tag-btn--active'));
      btn.classList.add('tag-btn--active');
      const tag = btn.dataset.tag!;

      // Standalone items
      const standaloneItems = [featured, ...cards].filter(Boolean) as HTMLElement[];
      standaloneItems.forEach(el => {
        if (tag === 'all') {
          el.style.display = '';
        } else {
          const tags = (el.dataset.tags || '').split(',');
          el.style.display = tags.includes(tag) ? '' : 'none';
        }
      });

      // Series rows — show if any post in the series has the tag
      seriesRows.forEach(row => {
        if (tag === 'all') {
          row.style.display = '';
        } else {
          const tags = (row.dataset.tags || '').split(',');
          row.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>

<style>
  .blog-page {
    padding-top: calc(var(--nav-height) + var(--space-3xl));
    padding-bottom: var(--space-4xl);
    min-height: 100vh;
  }

  /* ─── Header ─── */
  .blog-header {
    margin-bottom: var(--space-xl);
  }

  .blog-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .blog-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 48rem;
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .medium-link {
    color: var(--cyan);
    font-weight: 500;
  }

  .medium-link:hover {
    text-decoration: underline;
  }

  .blog-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .post-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  /* ─── Tag Filter ─── */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .tag-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.35em 0.85em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.15s var(--ease-out);
    white-space: nowrap;
  }

  .tag-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    background: rgba(255, 255, 255, 0.02);
  }

  .tag-btn--active {
    color: var(--cyan);
    border-color: rgba(0, 217, 255, 0.3);
    background: var(--cyan-glow);
  }

  /* ─── Series Section ─── */
  .series-section {
    margin-bottom: var(--space-3xl);
  }

  .series-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .series-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--amber);
    background: var(--amber-glow);
    border: 1px solid rgba(255, 157, 61, 0.28);
    padding: 0.2em 0.65em;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .series-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .series-count {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-left: auto;
  }

  .series-scroll-hint {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    opacity: 0.6;
  }

  /* ─── Carousel ─── */
  .series-carousel {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    padding-bottom: var(--space-sm);
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* Slight right padding reveals edge of the next card */
    padding-right: 4rem;
  }

  .series-carousel::-webkit-scrollbar {
    height: 3px;
  }

  .series-carousel::-webkit-scrollbar-track {
    background: transparent;
  }

  .series-carousel::-webkit-scrollbar-thumb {
    background: var(--border-hover);
    border-radius: 2px;
  }

  /* ─── Series Card ─── */
  .series-card {
    flex: 0 0 22rem;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s var(--ease-out),
                transform 0.3s var(--ease-out),
                box-shadow 0.3s var(--ease-out);
  }

  .series-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, var(--amber), transparent 80%);
  }

  .series-card:hover {
    border-color: rgba(255, 157, 61, 0.28);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3),
                0 0 0 1px rgba(255, 157, 61, 0.1);
    color: inherit;
  }

  .series-part {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--amber);
    margin-bottom: var(--space-sm);
  }

  .series-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .series-card-meta time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .series-card-tags {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .series-card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-sm);
    transition: color 0.2s var(--ease-out);
  }

  .series-card:hover .series-card-title {
    color: var(--amber);
  }

  .series-card-desc {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.65;
    flex: 1;
  }

  .series-read-link {
    margin-top: var(--space-lg);
    color: var(--amber);
  }

  .series-card:hover .series-read-link {
    gap: var(--space-sm);
  }

  /* ─── Articles Divider ─── */
  .articles-divider {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    margin-top: var(--space-lg);
  }

  .articles-divider-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .articles-divider-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* ─── Featured Card ─── */
  .featured-card {
    display: flex;
    text-decoration: none;
    color: inherit;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    margin-bottom: var(--space-2xl);
    transition: border-color 0.3s var(--ease-out),
                transform 0.3s var(--ease-out),
                box-shadow 0.3s var(--ease-out);
  }

  .featured-card:hover {
    border-color: rgba(0, 217, 255, 0.2);
    transform: translateY(-2px);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.35),
                0 0 0 1px rgba(0, 217, 255, 0.08);
    color: inherit;
  }

  .featured-accent {
    width: 4px;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--cyan), var(--amber));
  }

  .featured-body {
    flex: 1;
    padding: var(--space-xl) var(--space-2xl);
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--bg-deep);
    background: var(--cyan);
    padding: 0.2em 0.65em;
    border-radius: var(--radius-full);
  }

  .featured-meta time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .reading-time::before {
    content: '·';
    margin-right: var(--space-xs);
  }

  .medium-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-sm);
  }

  .featured-tags {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: var(--space-md);
    transition: color 0.2s var(--ease-out);
  }

  .featured-card:hover .featured-title {
    color: var(--cyan);
  }

  .featured-desc {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    max-width: 48rem;
  }

  .read-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--cyan);
    transition: gap 0.2s var(--ease-out);
  }

  .featured-card:hover .read-link {
    gap: var(--space-sm);
  }

  .read-arrow {
    transition: transform 0.2s var(--ease-out);
  }

  .featured-card:hover .read-arrow {
    transform: translateX(2px);
  }

  /* ─── Post Grid ─── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color 0.3s var(--ease-out),
                transform 0.3s var(--ease-out),
                box-shadow 0.3s var(--ease-out);
  }

  .post-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3),
                0 0 0 1px var(--border-hover);
    color: inherit;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .post-card-meta time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .post-card-tags {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .pill--sm {
    font-size: 0.65rem;
    padding: 0.15em 0.55em;
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
    margin-bottom: var(--space-sm);
    transition: color 0.2s var(--ease-out);
  }

  .post-card:hover .post-card-title {
    color: var(--cyan);
  }

  .post-card-desc {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.65;
    flex: 1;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .blog-title {
      font-size: var(--text-4xl);
    }

    .featured-body {
      padding: var(--space-lg);
    }

    .featured-title {
      font-size: var(--text-2xl);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .series-card {
      flex: 0 0 80vw;
    }

    .series-scroll-hint {
      display: none;
    }
  }
</style>
