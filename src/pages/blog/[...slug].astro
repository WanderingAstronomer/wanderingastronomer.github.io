---
import Layout from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog'))
    .filter(p => !p.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] || null,
      next: posts[i - 1] || null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

function estimateReadingTime(body: string | undefined) {
  if (!body) return 1;
  return Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 250));
}

const readTime = estimateReadingTime(post.body);
---

<Layout title={`${post.data.title} — Andrew Brown`} description={post.data.description}>
  <!-- Reading progress bar -->
  <div class="progress-track" aria-hidden="true">
    <div class="progress-bar" id="reading-progress"></div>
  </div>

  <article class="blog-post">
    <header class="post-header container">
      <a href="/blog" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Blog
      </a>
      <div class="post-meta-row">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="meta-dot">·</span>
        <span class="reading-time">{readTime} min read</span>
        {post.data.canonicalUrl && (
          <>
            <span class="meta-dot">·</span>
            <a href={post.data.canonicalUrl} target="_blank" rel="noopener noreferrer" class="medium-link-inline">
              View on Medium
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </>
        )}
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.tags && (
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <span class="pill">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content container--prose">
      <Content />
    </div>

    <!-- Post navigation -->
    <nav class="post-nav container">
      <div class="post-nav-inner">
        {prev ? (
          <a href={`/blog/${prev.id}`} class="nav-link nav-link--prev">
            <span class="nav-label">← Older</span>
            <span class="nav-title">{prev.data.title}</span>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/blog/${next.id}`} class="nav-link nav-link--next">
            <span class="nav-label">Newer →</span>
            <span class="nav-title">{next.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>
  </article>
</Layout>

<script>
  const bar = document.getElementById('reading-progress')!;
  const article = document.querySelector('.post-content')!;

  function updateProgress() {
    const rect = article.getBoundingClientRect();
    const total = rect.height;
    const scrolled = Math.max(0, -rect.top);
    const pct = Math.min(100, (scrolled / (total - window.innerHeight * 0.3)) * 100);
    bar.style.width = `${pct}%`;
  }

  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
</script>

<style>
  /* ─── Progress Bar ─── */
  .progress-track {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: transparent;
    z-index: 1000;
  }

  .progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--cyan), var(--amber));
    transition: width 0.1s linear;
    box-shadow: 0 0 8px var(--cyan-glow);
  }

  /* ─── Layout ─── */
  .blog-post {
    padding-top: calc(var(--nav-height) + var(--space-2xl));
    padding-bottom: var(--space-4xl);
  }

  .container--prose {
    max-width: 44rem;
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  /* ─── Header ─── */
  .post-header {
    max-width: 52rem;
    margin-inline: auto;
    margin-bottom: var(--space-3xl);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-xl);
    transition: color 0.2s var(--ease-out);
  }

  .back-link:hover {
    color: var(--cyan);
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  .post-meta-row time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .meta-dot {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .medium-link-inline {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s var(--ease-out);
  }

  .medium-link-inline:hover {
    color: var(--cyan);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
  }

  .post-tags {
    display: flex;
    gap: var(--space-sm);
  }

  /* ─── Prose ─── */
  .post-content {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: 1.85;
  }

  .post-content :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .post-content :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-lg);
  }

  .post-content :global(a) {
    color: var(--cyan);
    text-decoration: underline;
    text-decoration-color: rgba(0, 217, 255, 0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }

  .post-content :global(a:hover) {
    text-decoration-color: var(--cyan);
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-card);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  .post-content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    overflow-x: auto;
    margin-bottom: var(--space-xl);
  }

  .post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--cyan);
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .post-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .post-content :global(img) {
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    margin-block: var(--space-xl);
  }

  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan-dim), transparent);
    margin-block: var(--space-3xl);
  }

  /* ─── Post Navigation ─── */
  .post-nav {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--border);
  }

  .post-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    max-width: 52rem;
    margin-inline: auto;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: border-color 0.2s var(--ease-out), transform 0.2s var(--ease-out);
  }

  .nav-link:hover {
    border-color: var(--border-hover);
    transform: translateY(-1px);
  }

  .nav-link--next {
    text-align: right;
  }

  .nav-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .nav-title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .nav-link:hover .nav-title {
    color: var(--cyan);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .post-title {
      font-size: var(--text-3xl);
    }

    .post-nav-inner {
      grid-template-columns: 1fr;
    }

    .nav-link--next {
      text-align: left;
    }
  }
</style>
